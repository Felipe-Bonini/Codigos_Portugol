Algoritmo "ALG_SM_10N"
// Lógica de programaçăo
// Agnaldo Ferraz 
// Autor(a)    : Felipe Bonini
// Data atual  : 08/05/2025
Var
n, s, i : inteiro

Inicio
s<-0

para i de 1 ate 10 faca
escreva("Digite o ", i, "ş número: ")
leia (n)
s <- s + n
fimpara

escreval ("A soma dos 10 numeros é: ", s)

Fimalgoritmo